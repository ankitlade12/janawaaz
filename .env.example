# Postgres with pgvector (docker-compose up -d gives you this locally)
DATABASE_URL=postgresql+psycopg://janawaaz:janawaaz@localhost:5433/janawaaz

# LLM for summaries + the match verifier: EITHER key works (Claude preferred if both).
ANTHROPIC_API_KEY=
CLAUDE_MODEL=claude-opus-4-8
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash

# Embeddings are separate: Anthropic has no embeddings API, so semantic vectors
# come from Gemini text-embedding-004 (768-dim; free AI Studio key works) or
# "dev" (deterministic offline fallback, development only).
EMBEDDINGS_PROVIDER=gemini

# Sarvam AI — Indic translation for alerts
SARVAM_API_KEY=

# Telegram bot for push alerts
TELEGRAM_BOT_TOKEN=

# Voice alerts (Sarvam Bulbul TTS -> Telegram audio). Off by default: costs credits.
VOICE_ALERTS=false

# Render API key — used by the cron trigger script to start the workflow root task
RENDER_API_KEY=

# Matching knobs
SIMILARITY_THRESHOLD=0.50
